# Sandbox databases
EVENTS_POSTGRES_DB=events
EVENTS_POSTGRES_USER=postgres
EVENTS_POSTGRES_PASSWORD=postgres
EVENTS_POSTGRES_HOST=postgres
EVENTS_POSTGRES_PORT=5432

QUEUE_POSTGRES_DB=queue
QUEUE_POSTGRES_USER=postgres
QUEUE_POSTGRES_PASSWORD=postgres
QUEUE_POSTGRES_HOST=postgres
QUEUE_POSTGRES_PORT=5432

RASBHARI_POSTGRES_DB=rasbhari
RASBHARI_POSTGRES_USER=postgres
RASBHARI_POSTGRES_PASSWORD=postgres
RASBHARI_POSTGRES_HOST=postgres
RASBHARI_POSTGRES_PORT=5432

NOTIFICATIONS_POSTGRES_DB=notifications
NOTIFICATIONS_POSTGRES_USER=postgres
NOTIFICATIONS_POSTGRES_PASSWORD=postgres
NOTIFICATIONS_POSTGRES_HOST=postgres
NOTIFICATIONS_POSTGRES_PORT=5432

THOUGHTS_POSTGRES_DB=thoughts
THOUGHTS_POSTGRES_USER=postgres
THOUGHTS_POSTGRES_PASSWORD=postgres
THOUGHTS_POSTGRES_HOST=postgres
THOUGHTS_POSTGRES_PORT=5432

# Sandbox server
SERVER_DEBUG=False
SERVER_PORT=5000
SERVER_FILES_FOLDER=/tmp/rasbhari-sandbox/files
FLASK_SECRET_KEY=rasbhari-sandbox-secret
OPEN_WEBUI_URL=http://localhost:8080
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_COMMAND_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=20

# Sandbox logging
LOG_DIR=/tmp/rasbhari-sandbox/logs

# Sandbox notifications
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=rasbhari-sandbox
COURIER_SENDER_EMAIL=sandbox@example.com
COURIER_RECEIVER_EMAIL=sandbox@example.com
SENDGRID_API_KEY=
